    <menuitem id="menu_ecosphere_emission_factors"
              name="Emission Factors"
              parent="ecosphere_base.menu_ecosphere_config"
              action="action_ecosphere_emission_factor"
              sequence="20"
              groups="ecosphere_base.group_ecosphere_admin,ecosphere_base.group_ecosphere_compliance"/>
