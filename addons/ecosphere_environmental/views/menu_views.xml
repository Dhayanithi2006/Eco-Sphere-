              name="Environmental"
              parent="ecosphere_base.menu_ecosphere_root"
              sequence="20"/>

    <!-- Carbon Ledger Menu -->
    <menuitem id="menu_ecosphere_carbon_ledger"
              name="Carbon Ledger"
              parent="menu_ecosphere_environmental"
              action="action_ecosphere_carbon_transaction"
              sequence="10"/>

    <!-- Carbon Goals Menu -->
    <menuitem id="menu_ecosphere_carbon_goals"
              name="Carbon Goals"
              parent="menu_ecosphere_environmental"
