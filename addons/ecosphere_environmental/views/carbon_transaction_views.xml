<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_carbon_transaction_tree" model="ir.ui.view">
        <field name="name">ecosphere.carbon.transaction.tree</field>
        <field name="model">ecosphere.carbon.transaction</field>
        <field name="arch" type="xml">
            <list string="Carbon Transactions">
                <field name="date"/>
                <field name="name"/>
                <field name="activity_type"/>
                <field name="quantity" sum="Total Quantity"/>
                <field name="unit"/>
                <field name="co2_eq" sum="Total CO2e"/>
                <field name="department_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'under_review'" decoration-success="state in ('approved', 'published')"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_carbon_transaction_form" model="ir.ui.view">
        <field name="name">ecosphere.carbon.transaction.form</field>
        <field name="model">ecosphere.carbon.transaction</field>
        <field name="arch" type="xml">
            <form string="Carbon Transaction">
                <header>
                    <button name="action_submit" type="object" string="Submit for Approval" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" class="oe_highlight" invisible="state != 'under_review'" groups="ecosphere_base.group_ecosphere_manager,ecosphere_base.group_ecosphere_compliance"/>
                    <button name="action_publish" type="object" string="Publish" class="oe_highlight" invisible="state != 'approved'" groups="ecosphere_base.group_ecosphere_manager,ecosphere_base.group_ecosphere_compliance"/>
                    <button name="action_draft" type="object" string="Reset to Draft" invisible="state not in ('under_review', 'approved')" groups="ecosphere_base.group_ecosphere_manager,ecosphere_base.group_ecosphere_compliance"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,under_review,approved,published"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Q2 Fleet Fuel Logging" readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Log Activity">
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="activity_type" readonly="state != 'draft'"/>
                            <field name="quantity" readonly="state != 'draft'"/>
                            <field name="emission_factor_id" readonly="state != 'draft'"/>
                        </group>
                        <group string="Audit &amp; Footprint">
                            <label for="co2_eq"/>
                            <div class="o_row">
                                <field name="co2_eq" readonly="1"/>
                                <span>tCO2e</span>
                            </div>
                            <field name="unit" readonly="1"/>
                            <field name="department_id" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_carbon_transaction_kanban" model="ir.ui.view">
        <field name="name">ecosphere.carbon.transaction.kanban</field>
        <field name="model">ecosphere.carbon.transaction</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1">
                <field name="name"/>
                <field name="co2_eq"/>
                <field name="date"/>
                <field name="activity_type"/>
                <field name="department_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div>
                                    <field name="date"/>
                                </div>
                                <div class="mt4">
                                    <span>Footprint: <strong><field name="co2_eq"/> tCO2e</strong></span>
                                </div>
                                <div class="mt4">
                                    <span class="badge rounded-pill text-bg-info"><field name="activity_type"/></span>
                                </div>
                                <div class="mt4 text-muted">
                                    <field name="department_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_carbon_transaction_graph" model="ir.ui.view">
        <field name="name">ecosphere.carbon.transaction.graph</field>
        <field name="model">ecosphere.carbon.transaction</field>
        <field name="arch" type="xml">
            <graph string="Emissions Analysis" type="bar" sample="1">
                <field name="activity_type"/>
                <field name="co2_eq" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_carbon_transaction_search" model="ir.ui.view">
        <field name="name">ecosphere.carbon.transaction.search</field>
        <field name="model">ecosphere.carbon.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Carbon Ledger">
                <field name="name"/>
                <field name="department_id"/>
                <filter string="Scope 1 (Direct Fuel)" name="filter_scope1" domain="[('activity_type', 'in', ('stationary_combustion', 'mobile_combustion'))]"/>
                <filter string="Scope 2 (Electricity)" name="filter_scope2" domain="[('activity_type', '=', 'electricity')]"/>
                <filter string="Scope 3 (Indirect/Travel)" name="filter_scope3" domain="[('activity_type', 'in', ('travel', 'waste'))]"/>
                <separator/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Under Review" name="filter_review" domain="[('state', '=', 'under_review')]"/>
                <filter string="Approved" name="filter_approved" domain="[('state', 'in', ('approved', 'published'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="group_by_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Scope Activity" name="group_by_activity" context="{'group_by': 'activity_type'}"/>
                    <filter string="Transaction Month" name="group_by_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ecosphere_carbon_transaction" model="ir.actions.act_window">
        <field name="name">Carbon Ledger</field>
        <field name="res_model">ecosphere.carbon.transaction</field>
        <field name="view_mode">list,form,kanban,graph</field>
        <field name="search_view_id" ref="view_carbon_transaction_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Log your organizational utility emissions data here.
            </p>
            <p>
                Track fleet gasoline, utility invoices, travel mileage, and waste calculations in a unified registry.
            </p>
        </field>
    </record>
</odoo>
