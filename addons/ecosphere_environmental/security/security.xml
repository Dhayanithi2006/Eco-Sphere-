<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Carbon Transaction Rules -->

        <!-- Employee Rule: Can only see carbon transactions in their own department -->
        <record id="rule_carbon_transaction_employee" model="ir.rule">
            <field name="name">Employee Carbon Transactions: Departmental View</field>
            <field name="model_id" ref="model_ecosphere_carbon_transaction"/>
            <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager Rule: Can manage transactions in their department -->
        <record id="rule_carbon_transaction_manager" model="ir.rule">
            <field name="name">Manager Carbon Transactions: Departmental Administration</field>
            <field name="model_id" ref="model_ecosphere_carbon_transaction"/>
            <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Auditor Rule: Global read-only view of carbon transactions -->
        <record id="rule_carbon_transaction_auditor" model="ir.rule">
            <field name="name">Auditor Carbon Transactions: Global read-only</field>
            <field name="model_id" ref="model_ecosphere_carbon_transaction"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_auditor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Compliance & Admin: Global read/write access -->
        <record id="rule_carbon_transaction_compliance" model="ir.rule">
            <field name="name">Compliance Officer Carbon Transactions: Global Access</field>
            <field name="model_id" ref="model_ecosphere_carbon_transaction"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_compliance')), (4, ref('ecosphere_base.group_ecosphere_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Environmental Goals Rules -->

        <!-- Employee: Can view own department goals -->
        <record id="rule_environmental_goal_employee" model="ir.rule">
            <field name="name">Employee Goals: Departmental View</field>
            <field name="model_id" ref="model_ecosphere_environmental_goal"/>
            <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager: Can view & write own department goals -->
        <record id="rule_environmental_goal_manager" model="ir.rule">
            <field name="name">Manager Goals: Departmental Management</field>
            <field name="model_id" ref="model_ecosphere_environmental_goal"/>
            <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Auditor & Compliance & Admin: Global goals access -->
        <record id="rule_environmental_goal_global" model="ir.rule">
            <field name="name">Global ESG Goals Access</field>
            <field name="model_id" ref="model_ecosphere_environmental_goal"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_auditor')), (4, ref('ecosphere_base.group_ecosphere_compliance')), (4, ref('ecosphere_base.group_ecosphere_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
