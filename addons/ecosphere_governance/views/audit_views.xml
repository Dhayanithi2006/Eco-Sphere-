<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_audit_tree" model="ir.ui.view">
        <field name="name">ecosphere.audit.tree</field>
        <field name="model">ecosphere.audit</field>
        <field name="arch" type="xml">
            <list string="Compliance Audits">
                <field name="name"/>
                <field name="audit_type"/>
                <field name="auditor_id"/>
                <field name="audit_date"/>
                <field name="score"/>
                <field name="compliance_status" widget="badge" decoration-success="compliance_status == 'compliant'" decoration-warning="compliance_status == 'non_compliant'" decoration-danger="compliance_status == 'critical_non_compliant'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_audit_form" model="ir.ui.view">
        <field name="name">ecosphere.audit.form</field>
        <field name="model">ecosphere.audit</field>
        <field name="arch" type="xml">
            <form string="Compliance Audit">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. FY2026 Environmental Audit"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Audit Schedule">
                            <field name="audit_type"/>
                            <field name="auditor_id"/>
                            <field name="audit_date"/>
                        </group>
                        <group string="Auditor Evaluation">
                            <field name="score"/>
                            <field name="compliance_status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Observations &amp; Gaps" name="observations">
                            <field name="notes" placeholder="Specify observations, non-compliance markers, and suggested remediation steps..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ecosphere_audit" model="ir.actions.act_window">
        <field name="name">Compliance Audits</field>
        <field name="res_model">ecosphere.audit</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register audits.
            </p>
            <p>
                Track internal evaluations or external audits, recording compliance ratings.
            </p>
        </field>
    </record>
</odoo>
