<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_risk_tree" model="ir.ui.view">
        <field name="name">ecosphere.risk.tree</field>
        <field name="model">ecosphere.risk</field>
        <field name="arch" type="xml">
            <list string="Risk Register">
                <field name="title"/>
                <field name="category"/>
                <field name="likelihood"/>
                <field name="impact"/>
                <field name="score"/>
                <field name="risk_level" widget="badge" decoration-success="risk_level == 'low'" decoration-warning="risk_level == 'medium'" decoration-danger="risk_level == 'high'"/>
                <field name="owner_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_risk_form" model="ir.ui.view">
        <field name="name">ecosphere.risk.form</field>
        <field name="model">ecosphere.risk</field>
        <field name="arch" type="xml">
            <form string="Sustainability Risk">
                <sheet>
                    <div class="oe_title">
                        <label for="title" class="oe_edit_only"/>
                        <h1>
                            <field name="title" placeholder="e.g. Supply Chain Emissions Failure"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Risk Assessment">
                            <field name="category"/>
                            <field name="likelihood"/>
                            <field name="impact"/>
                        </group>
                        <group string="Risk Calculation">
                            <field name="score" readonly="1"/>
                            <field name="risk_level" readonly="1"/>
                            <field name="owner_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mitigation Strategy" name="mitigation">
                            <field name="mitigation_plan" placeholder="Details of business actions to mitigate, transfer, or accept this risk..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_risk_kanban" model="ir.ui.view">
        <field name="name">ecosphere.risk.kanban</field>
        <field name="model">ecosphere.risk</field>
        <field name="arch" type="xml">
            <kanban default_group_by="risk_level" sample="1">
                <field name="title"/>
                <field name="score"/>
                <field name="category"/>
                <field name="owner_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="title"/></strong>
                                <div><field name="category"/></div>
                                <div class="mt4">
                                    <span>Score: <strong><field name="score"/></strong></span>
                                </div>
                                <div class="mt4 text-muted text-end">
                                    <field name="owner_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_risk_graph" model="ir.ui.view">
        <field name="name">ecosphere.risk.graph</field>
        <field name="model">ecosphere.risk</field>
        <field name="arch" type="xml">
            <graph string="Risks Matrix Analysis" type="bar" sample="1">
                <field name="category"/>
                <field name="score" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ecosphere_risk" model="ir.actions.act_window">
        <field name="name">Risk Register</field>
        <field name="res_model">ecosphere.risk</field>
        <field name="view_mode">list,form,kanban,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage your ESG and sustainability risks.
            </p>
            <p>
                Map operational hazards using Likelihood × Impact matrices to track priority mitigation plans.
            </p>
        </field>
    </record>
</odoo>
