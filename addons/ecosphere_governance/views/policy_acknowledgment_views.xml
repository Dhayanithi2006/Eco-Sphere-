<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_policy_acknowledgment_tree" model="ir.ui.view">
        <field name="name">ecosphere.policy.acknowledgment.tree</field>
        <field name="model">ecosphere.policy.acknowledgment</field>
        <field name="arch" type="xml">
            <list string="Policy Sign-offs">
                <field name="policy_id"/>
                <field name="employee_id"/>
                <field name="acknowledged_date"/>
                <field name="state" widget="badge" decoration-warning="state == 'pending'" decoration-success="state == 'acknowledged'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_policy_acknowledgment_form" model="ir.ui.view">
        <field name="name">ecosphere.policy.acknowledgment.form</field>
        <field name="model">ecosphere.policy.acknowledgment</field>
        <field name="arch" type="xml">
            <form string="Policy Sign-off">
                <header>
                    <button name="action_acknowledge" type="object" string="Acknowledge Policy" class="oe_highlight" invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,acknowledged"/>
                </header>
                <sheet>
                    <group>
                        <group string="Sign-off Scope">
                            <field name="policy_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                        </group>
                        <group string="Audit Validation">
                            <field name="acknowledged_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ecosphere_policy_acknowledgment" model="ir.actions.act_window">
        <field name="name">Policy Sign-offs</field>
        <field name="res_model">ecosphere.policy.acknowledgment</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage employee policy sign-offs.
            </p>
            <p>
                Employees review and sign off published compliance documents here.
            </p>
        </field>
    </record>
</odoo>
