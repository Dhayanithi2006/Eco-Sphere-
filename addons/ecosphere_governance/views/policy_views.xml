<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_policy_tree" model="ir.ui.view">
        <field name="name">ecosphere.policy.tree</field>
        <field name="model">ecosphere.policy</field>
        <field name="arch" type="xml">
            <list string="Policies">
                <field name="name"/>
                <field name="version"/>
                <field name="active"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'review'" decoration-success="state == 'published'" decoration-muted="state == 'archived'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_policy_form" model="ir.ui.view">
        <field name="name">ecosphere.policy.form</field>
        <field name="model">ecosphere.policy</field>
        <field name="arch" type="xml">
            <form string="Policy Document">
                <header>
                    <button name="action_submit" type="object" string="Submit to Review" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_publish" type="object" string="Publish Policy" class="oe_highlight" invisible="state != 'review'" groups="ecosphere_base.group_ecosphere_compliance,ecosphere_base.group_ecosphere_admin"/>
                    <button name="action_archive" type="object" string="Archive Policy" invisible="state not in ('published')" groups="ecosphere_base.group_ecosphere_compliance,ecosphere_base.group_ecosphere_admin"/>
                    <button name="action_draft" type="object" string="Reset to Draft" invisible="state not in ('review', 'archived')" groups="ecosphere_base.group_ecosphere_compliance,ecosphere_base.group_ecosphere_admin"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,published,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Code of Business Conduct" readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Metadata">
                            <field name="version" readonly="state != 'draft'"/>
                            <field name="active" readonly="state != 'draft'"/>
                        </group>
                        <group string="Distribution Target">
                            <field name="target_department_ids" widget="many2many_tags" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Document File" name="document_file">
                            <group>
                                <field name="file_attachment" filename="name" readonly="state != 'draft'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ecosphere_policy" model="ir.actions.act_window">
        <field name="name">Policies</field>
        <field name="res_model">ecosphere.policy</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage compliance and corporate ESG policy papers.
            </p>
            <p>
                Author, review, and publish code guidelines, safety rules, and operational requirements.
            </p>
        </field>
    </record>
</odoo>
