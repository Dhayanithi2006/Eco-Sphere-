<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_ai_history_tree" model="ir.ui.view">
        <field name="name">ecosphere.ai.history.tree</field>
        <field name="model">ecosphere.ai.history</field>
        <field name="arch" type="xml">
            <list string="Consultation Logs" create="false" edit="false">
                <field name="date"/>
                <field name="name"/>
                <field name="confidence_score" widget="progressbar"/>
                <field name="user_rating" widget="badge" decoration-success="user_rating == 'like'" decoration-danger="user_rating == 'dislike'" decoration-muted="user_rating == 'none'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_ai_history_form" model="ir.ui.view">
        <field name="name">ecosphere.ai.history.form</field>
        <field name="model">ecosphere.ai.history</field>
        <field name="arch" type="xml">
            <form string="Consultation Log" create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Metadata">
                            <field name="date" readonly="1"/>
                            <field name="confidence_score" readonly="1"/>
                        </group>
                        <group string="Validation Feedback">
                            <field name="user_rating" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Context Prompt" name="prompt">
                            <field name="prompt" readonly="1"/>
                        </page>
                        <page string="Advisory Output" name="response">
                            <field name="response" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ecosphere_ai_history" model="ir.actions.act_window">
        <field name="name">Consultation Logs</field>
        <field name="res_model">ecosphere.ai.history</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Review advisor consultation histories.
            </p>
            <p>
                Every query sent to the AI decision support assistant is recorded here with rating metrics.
            </p>
        </field>
    </record>
</odoo>
