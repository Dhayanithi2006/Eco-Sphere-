<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- CSR Activities -->
        <record id="activity_tree_planting" model="ecosphere.csr.activity">
            <field name="name">Annual Tree Planting Initiative 2026</field>
            <field name="type">environmental</field>
            <field name="start_date">2026-07-01</field>
            <field name="end_date">2026-07-31</field>
            <field name="volunteer_hours_target">100.0</field>
            <field name="state">active</field>
        </record>

        <record id="activity_recycling_drive" model="ecosphere.csr.activity">
            <field name="name">Electronic Waste Recycling Drive</field>
            <field name="type">environmental</field>
            <field name="start_date">2026-08-01</field>
            <field name="end_date">2026-08-15</field>
            <field name="volunteer_hours_target">40.0</field>
            <field name="state">draft</field>
        </record>

        <!-- Volunteer Logs -->
        <record id="participation_siddharth" model="ecosphere.csr.participation">
            <field name="activity_id" ref="activity_tree_planting"/>
            <field name="employee_id" ref="ecosphere_base.user_esg_employee"/>
            <field name="hours_logged">8.0</field>
            <field name="state">approved</field>
            <field name="notes">Assisted in coordinating operations team and planted 15 trees.</field>
        </record>

        <!-- Update Siddharth points to match approved hours (8 hours * 10 = 80 points) -->
        <record id="ecosphere_base.user_esg_employee" model="res.users">
            <field name="esg_points">80</field>
        </record>

        <!-- Training Sessions -->
        <record id="training_dei" model="ecosphere.training">
            <field name="name">EcoSphere DEI and Sustainable Leadership Workshop</field>
            <field name="type">diversity</field>
            <field name="date">2026-07-08</field>
            <field name="attendee_ids" eval="[(4, ref('ecosphere_base.user_esg_employee')), (4, ref('ecosphere_base.user_esg_manager'))]"/>
            <field name="completion_rate">100.0</field>
            <field name="notes">Covers inclusion indicators, corporate governance structures, and social ESG compliance rules.</field>
        </record>

        <!-- Diversity scorecards for base departments -->
        <record id="diversity_ops" model="ecosphere.diversity.dashboard">
            <field name="department_id" ref="ecosphere_base.dept_operations"/>
            <field name="female_ratio">40.0</field>
            <field name="male_ratio">60.0</field>
            <field name="other_ratio">0.0</field>
            <field name="avg_age">38.5</field>
            <field name="ethnic_diversity_index">2.8</field>
        </record>

        <record id="diversity_hr" model="ecosphere.diversity.dashboard">
            <field name="department_id" ref="ecosphere_base.dept_hr"/>
            <field name="female_ratio">70.0</field>
            <field name="male_ratio">25.0</field>
            <field name="other_ratio">5.0</field>
            <field name="avg_age">31.0</field>
            <field name="ethnic_diversity_index">3.2</field>
        </record>
    </data>
</odoo>
