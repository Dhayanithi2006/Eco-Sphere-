<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Record Rules for CSR Participation -->

        <!-- Employee Rule: Can only see/write own volunteer records -->
        <record id="rule_csr_participation_employee" model="ir.rule">
            <field name="name">Employee CSR Participation: Own logs only</field>
            <field name="model_id" ref="model_ecosphere_csr_participation"/>
            <field name="domain_force">[('employee_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Manager Rule: Can manage and approve department volunteer logs -->
        <record id="rule_csr_participation_manager" model="ir.rule">
            <field name="name">Manager CSR Participation: Departmental view</field>
            <field name="model_id" ref="model_ecosphere_csr_participation"/>
            <!-- Manager user can see employees in their department. Since res.users is linked to employee, we search on employee's department -->
            <field name="domain_force">[
                '|', 
                ('employee_id', '=', user.id),
                ('employee_id.employee_id.department_id', '=', user.employee_id.department_id.id)
            ]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Compliance & Auditor: Global View of CSR logs -->
        <record id="rule_csr_participation_global" model="ir.rule">
            <field name="name">Global CSR logs access</field>
            <field name="model_id" ref="model_ecosphere_csr_participation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_auditor')), (4, ref('ecosphere_base.group_ecosphere_compliance')), (4, ref('ecosphere_base.group_ecosphere_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
