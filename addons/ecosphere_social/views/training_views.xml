<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_training_tree" model="ir.ui.view">
        <field name="name">ecosphere.training.tree</field>
        <field name="model">ecosphere.training</field>
        <field name="arch" type="xml">
            <list string="Training Sessions">
                <field name="name"/>
                <field name="type"/>
                <field name="date"/>
                <field name="completion_rate"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_training_form" model="ir.ui.view">
        <field name="name">ecosphere.training.form</field>
        <field name="model">ecosphere.training</field>
        <field name="arch" type="xml">
            <form string="Training Session">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. DEI Fundamentals Training"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Program Details">
                            <field name="type"/>
                            <field name="date"/>
                        </group>
                        <group string="Outcome">
                            <field name="completion_rate"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Attendees" name="attendees">
                            <field name="attendee_ids" widget="many2many_tags" placeholder="Link employee user accounts..."/>
                        </page>
                        <page string="Syllabus &amp; Objectives" name="syllabus">
                            <field name="notes" placeholder="Summarize course goals and outcomes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ecosphere_training" model="ir.actions.act_window">
        <field name="name">Training Programs</field>
        <field name="res_model">ecosphere.training</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register sustainability and inclusion training events.
            </p>
            <p>
                Track employee course completions and certification progress.
            </p>
        </field>
    </record>
</odoo>
