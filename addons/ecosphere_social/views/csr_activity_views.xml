<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_csr_activity_tree" model="ir.ui.view">
        <field name="name">ecosphere.csr.activity.tree</field>
        <field name="model">ecosphere.csr.activity</field>
        <field name="arch" type="xml">
            <list string="CSR Activities">
                <field name="name"/>
                <field name="type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="volunteer_hours_target"/>
                <field name="volunteer_hours_actual"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-muted="state == 'completed'" decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_csr_activity_form" model="ir.ui.view">
        <field name="name">ecosphere.csr.activity.form</field>
        <field name="model">ecosphere.csr.activity</field>
        <field name="arch" type="xml">
            <form string="CSR Activity">
                <header>
                    <button name="action_activate" type="object" string="Launch Activity" class="oe_highlight" invisible="state != 'draft'" groups="ecosphere_base.group_ecosphere_compliance,ecosphere_base.group_ecosphere_admin"/>
                    <button name="action_complete" type="object" string="Complete Campaign" class="oe_highlight" invisible="state != 'active'" groups="ecosphere_base.group_ecosphere_compliance,ecosphere_base.group_ecosphere_admin"/>
                    <button name="action_cancel" type="object" string="Cancel Activity" invisible="state not in ('draft', 'active')" groups="ecosphere_base.group_ecosphere_compliance,ecosphere_base.group_ecosphere_admin"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,completed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Q3 Beach Cleanup Campaign" readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Campaign Parameters">
                            <field name="type" readonly="state != 'draft'"/>
                            <field name="start_date" readonly="state != 'draft'"/>
                            <field name="end_date" readonly="state != 'draft'"/>
                        </group>
                        <group string="Volunteer Ledger">
                            <field name="volunteer_hours_target" readonly="state != 'draft'"/>
                            <field name="volunteer_hours_actual"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ecosphere_csr_activity" model="ir.actions.act_window">
        <field name="name">CSR Activities</field>
        <field name="res_model">ecosphere.csr.activity</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Organize sustainability and community outreach campaigns.
            </p>
            <p>
                Create events for employees to participate, track logged targets, and award points.
            </p>
        </field>
    </record>
</odoo>
