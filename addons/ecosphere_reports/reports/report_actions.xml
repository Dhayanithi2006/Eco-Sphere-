<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Environmental Summary Report Action -->
    <record id="action_report_environmental_summary" model="ir.actions.report">
        <field name="name">Environmental Summary Brief</field>
        <field name="model">hr.department</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ecosphere_reports.report_environmental_summary</field>
        <field name="report_file">ecosphere_reports.report_environmental_summary</field>
        <field name="print_report_name">'Environmental_Summary_%s' % (object.name)</field>
        <field name="binding_model_id" ref="hr.model_hr_department"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ESG Executive Summary Report Action -->
    <record id="action_report_esg_executive_summary" model="ir.actions.report">
        <field name="name">ESG Executive Summary Report</field>
        <field name="model">res.company</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ecosphere_reports.report_esg_executive_summary</field>
        <field name="report_file">ecosphere_reports.report_esg_executive_summary</field>
        <field name="print_report_name">'ESG_Executive_Report_%s' % (object.name)</field>
        <field name="binding_model_id" ref="base.model_res_company"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
