<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Notification isolation rule -->
        <record id="rule_notification_employee" model="ir.rule">
            <field name="name">Employee Notifications: Own Only</field>
            <field name="model_id" ref="model_ecosphere_notification"/>
            <field name="domain_force">[('recipient_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Global view rules for other groups -->
        <record id="rule_notification_global" model="ir.rule">
            <field name="name">Global Notifications Access</field>
            <field name="model_id" ref="model_ecosphere_notification"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_manager')), (4, ref('ecosphere_base.group_ecosphere_auditor')), (4, ref('ecosphere_base.group_ecosphere_compliance')), (4, ref('ecosphere_base.group_ecosphere_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
