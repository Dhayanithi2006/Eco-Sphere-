<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Point History Record Rules -->

        <!-- Employee: Can only view their own point transaction logs -->
        <record id="rule_point_history_employee" model="ir.rule">
            <field name="name">Employee Point History: Own Logs Only</field>
            <field name="model_id" ref="model_ecosphere_employee_point_history"/>
            <field name="domain_force">[('employee_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Compliance & Managers & Auditor: Global access to point records -->
        <record id="rule_point_history_global" model="ir.rule">
            <field name="name">Global Point History Access</field>
            <field name="model_id" ref="model_ecosphere_employee_point_history"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('ecosphere_base.group_ecosphere_manager')), (4, ref('ecosphere_base.group_ecosphere_auditor')), (4, ref('ecosphere_base.group_ecosphere_compliance')), (4, ref('ecosphere_base.group_ecosphere_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
