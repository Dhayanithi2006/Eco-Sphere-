<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_department_form_inherit_ecosphere" model="ir.ui.view">
        <field name="name">hr.department.form.inherit.ecosphere</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <notebook>
                    <page string="Sustainability &amp; ESG" name="sustainability_esg_dept">
                        <group>
                            <group string="ESG Oversight">
                                <field name="sustainability_manager_id"/>
                                <field name="department_target_co2"/>
                            </group>
                            <group string="Dynamic Performance (Calculated)">
                                <field name="dynamic_esg_score" readonly="1"/>
                                <field name="dynamic_esg_health" readonly="1"/>
                            </group>
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
